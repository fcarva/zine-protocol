generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PixChargeStatus {
  pending
  paid
  expired
  failed
}

enum SupportSource {
  web3
  pix
}

enum SupportMethod {
  wallet
  pix
  email
}

enum DaoProposalStatus {
  draft
  discussion
  temperature_check
  voting
  approved
  cancelled
  queued
  executed
  archived
}

model PixCharge {
  id                String          @id @default(cuid())
  chargeId          String          @unique
  zineSlug          String
  amountBrlCents    Int
  amountUsdc6       BigInt
  payerEmail        String
  payerWallet       String?
  status            PixChargeStatus @default(pending)
  pixQrCode         String
  pixCopyPaste      String
  expiresAt         DateTime
  paidAt            DateTime?
  webhookPayload    String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model SupportEvent {
  id             String        @id @default(cuid())
  source         SupportSource
  zineSlug       String
  amountUsdc6    BigInt
  amountBrlCents Int?
  payerEmail     String?
  payerWallet    String?
  txHash         String?
  chargeId       String?
  chainId        Int?
  revnetProject  Int
  createdAt      DateTime      @default(now())

  @@index([zineSlug])
  @@index([source])
  @@index([chargeId])
  @@index([txHash])
}

model SupportIntentEvent {
  id              String        @id @default(cuid())
  zineSlug        String
  method          SupportMethod
  surface         String
  sessionId       String
  intentId        String        @unique
  amountInput     String?
  currencyInput   String?
  chainId         Int?
  walletConnected Boolean?
  userAgent       String?
  createdAt       DateTime      @default(now())

  @@index([zineSlug])
  @@index([method])
  @@index([createdAt])
  @@index([surface])
}

model DaoProposal {
  id              String            @id @default(cuid())
  proposalCode    String            @unique
  slug            String            @unique
  title           String
  summary         String
  body            String
  status          DaoProposalStatus @default(discussion)
  cycleLabel      String
  governanceCycle Int?
  authorName      String
  authorWallet    String?
  quorumRequired  Int
  votesFor        Int               @default(0)
  votesAgainst    Int               @default(0)
  votesAbstain    Int               @default(0)
  source          String            @default("app")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([governanceCycle])
  @@index([createdAt])
  @@index([authorName])
}

